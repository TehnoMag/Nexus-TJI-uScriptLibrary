STATE SELFTEST

	RULE	event isClass
		:action
		
			leaveState();
			Return(1);
		
		:end
	END

END

STATE NEW //New instance constructor (Before instance)

	RULE	event In
		:action
			
			//Check if module `Class` is loaded
			ChooseFirst
			(
				isValid(U.uSL.Class),	localEvent(New),
				1,						localEvent(Abort)
			);
			
		:end
	END
	
	RULE	event New
		:action
		
			//Define service variables
			__Owner := 0;
			__Owner_ref := 0;
			__instance := 0;
						
			//Allocate variables stack
			U.uSL.Class:localEvent(AllocateVarStack);
		
		:end
	END
	
	RULE	event Abort
		:action
		
			debug("uSL module `Class` are not loaded");
			leaveState();
		
		:end
	END

END

STATE CLASS